    <div id="wrapper" class="pt-4">    <div style="min-height: 600px;" class="container desktop">
    <div style="min-height: 600px;" class="home-video d-flex flex-grow-1 mb-4">
        
        <div id="spinner" class="spinner-grow position-absolute" role="status">
            <span style="left: 50%; right: 50%; z-index: 200;" class="visually-hidden">Loading...</span>
        </div>
            <video style="object-fit: cover; height: 600px;" src="/m1/video_purple.mp4" id="video" class="video lazy-video" autoplay loop muted></video>
     
        <div class="overlay">
            <div class="row">
                <div class="col lol col-6" >
                    <div class="m-3 m-sm-5">
                        <h1 class="display-4">M1PPosu</h1>
                        <div class="lead-h">a osu! Server where we rank the unrankable! From HUGE Map Packs to Farm Maps, everything is rankable here, giving everyone and everything a chance to excel the rankings! With Vanilla, Relax and Autopilot leaderboards, you can never get bored!</div>
                            <div class="badge-grp">
                                <span class="home-badge"><span class="purple"></span> Registered</span>
                                <span class="home-badge"><span class="green"></span> Online</span>
                                <span class="home-badge d-none d-sm-inline"><span class="yellow">0</span> Clans</span>
                            </div>
                            <div class="badge-grp">
                                <span class="home-badge"><span class="red">0</span> Plays</span>
                                <span class="home-badge"><span class="cyan">0</span> Beatmaps</span>
                            </div>
                            <div class="mt-2">
                                <a class="btn btn-primary" href="/register" role="button">Register</a>
                            <a class="btn btn-discord" href="https://dsc.gg/m1ppand4ayo" role="button">Discord</a>
                            <a class="btn btn-secondary" href="/docs/connect">How to connect?</a>
                            </div>
                       
                    </div>


                </div>
                <div class="col col-6 logo-col">
                    <img src="/m1/m1header.webp" class="d-flex justify-content-center mx-auto"
                        style="width: inherit; max-width: 40%;" alt="">
                </div>

            </div>
        </div>
    </div>
</div>
    <section class="d-flex bg-body my-5" id="feature-cards" style="margin-top: 20px;">
    <div class="container">
        <div class="row text-center">
            <div class="col-12 col-lg-3 mb-4">
                <div class="shiina-up-card shiina-card border h-100 bg-secondary text-body rounded-3">
                    <div class="card-body d-flex flex-column align-items-center py-4">
                        <i class="fa fa-cloud-upload-alt fa-3x mb-3 text-primary"></i>
                        <h5 class="shiina-up-card-title card-title mb-3">Free osu!Direct</h5>
                        <p class="shiina-up-card-text card-text mx-1 mb-0">M1PPosu offers free osu!Direct with <a href="https://catboy.best" class="text-decoration-none text-primary">catboy.best</a></p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-3 mb-4">
                <div class="shiina-up-card shiina-card border h-100 bg-secondary text-body rounded-3">
                    <div class="card-body d-flex flex-column align-items-center py-4">
                        <i class="fa fa-desktop fa-3x mb-3 text-primary"></i>
                        <h5 class="shiina-up-card-title card-title mb-3">Performant Frontend</h5>
                        <p class="shiina-up-card-text card-text mx-1 mb-0">M1PPosu offers a stable and feature-rich website with <a href="https://osu-nolimits.github.io/wiki/" class="text-decoration-none text-primary">Shiina</a></p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-3 mb-4">
                <div class="shiina-up-card shiina-card border h-100 bg-secondary text-body rounded-3">
                    <div class="card-body d-flex flex-column align-items-center py-4">
                        <i class="fa fa-people-robbery fa-3x mb-3 text-primary"></i>
                        <h5 class="shiina-up-card-title card-title mb-3">Integrated Clans</h5>
                        <p class="shiina-up-card-text card-text mx-1 mb-0">M1PPosu offers competitive clan gameplay with statistics</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-3 mb-4">
                <div class="shiina-up-card shiina-card border h-100 bg-secondary text-body rounded-3">
                    <div class="card-body d-flex flex-column align-items-center py-4">
                        <i class="fa fa-wrench fa-3x mb-3 text-primary"></i>
                        <h5 class="shiina-up-card-title card-title mb-3">Maintained Environment</h5>
                        <p class="shiina-up-card-text card-text mx-1 mb-0">Our developers are working hard to improve our services</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
    <section class="bg-body py-5" id="server-stats">
    <div class="container">
        <div class="row text-center d-flex">
            <div class="col-12 col-md-4 mb-4 d-flex">
                <div class="stat-card shiina-card d-flex justify-content-between align-items-center bg-secondary text-body p-4 rounded-3 shadow-sm w-100">
                    <div class="d-flex align-items-center">
                        <i class="fa fa-server fa-3x me-3 text-primary"></i>
                        <div>
                            <h5 class="mb-0">Ingame Logins</h5>
                            <small class="text-muted">Today: 0</small>
                        </div>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-0">0</h4>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-4 mb-4 d-flex">
                <div class="stat-card shiina-card d-flex justify-content-between align-items-center bg-secondary text-body p-4 rounded-3 shadow-sm w-100">
                    <div class="d-flex align-items-center">
                        <i class="fa fa-users fa-3x me-3 text-primary"></i>
                        <div>
                            <h5 class="mb-0">Running Since</h5>
                        </div>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-0" data-timestamp-format="date" data-timestamp="2026-02-23 22:16:17">2026-02-23 22:16:17</h4>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-4 mb-4 d-flex">
                <div class="stat-card shiina-card d-flex justify-content-between align-items-center bg-secondary text-body p-4 rounded-3 shadow-sm w-100">
                    <div class="d-flex align-items-center">
                        <i class="fa fa-download fa-3x me-3 text-primary"></i>
                        <div>
                            <h5 class="mb-0">Staff Members</h5>
                        </div>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-0">0</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
